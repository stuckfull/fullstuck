{
    "production": false,
    "_ai_rules": "Run `php fullstuck.php docs` in your terminal to read the framework API documentation.",
    "database": {
        "default": "main",
        "connections": {
            "main": {
                "driver": "sqlite",
                "database_path": "database.sqlite"
            },
            "production": {
                "driver": "mysql",
                "host": "${DB_HOST}",
                "dbname": "${DB_NAME}",
                "username": "${DB_USER}",
                "password": "${DB_PASS}"
            }
        }
    },
    "require": ["globals"],
    "routing": {
        "base_path": "/",
        "public_folders": [
            "assets",
            "uploads",
            "storage/public"
        ]
    },
    "agent_js": true,
    "fragment": {
        "default_fragment": "body",
        "header_request": "X-FST-Request",
        "header_fragment": "X-FST-Fragment",
        "indicator_class": "fst-loading",
        "history_cache": false
    },
    "mime_types": {
        "css": "text/css",
        "js": "application/javascript",
        "jpg": "image/jpeg",
        "jpeg": "image/jpeg",
        "png": "image/png",
        "gif": "image/gif",
        "svg": "image/svg+xml",
        "woff": "font/woff",
        "woff2": "font/woff2",
        "ttf": "font/ttf",
        "eot": "application/vnd.ms-fontobject",
        "html": "text/html",
        "htm": "text/html",
        "txt": "text/plain",
        "json": "application/json",
        "pdf": "application/pdf"
    }
}